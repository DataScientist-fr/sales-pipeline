# Copier ce fichier en .env et adapter les valeurs à votre environnement.
# Ne jamais committer le fichier .env dans Git.

# Environnement d'exécution : development | production
ENV=development

# Chemins des données (relatifs à la racine du projet)
DATA_PATH=data/raw
OUTPUT_PATH=data/processed

# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
